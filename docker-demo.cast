[4.316, "o", "\u001b[7mcat docker-compose.yml\u001b[27m\r\r\n\u001b[K"]
[0.487, "o", "\u001b[A\u001b[49C\u001b[27mc\u001b[27ma\u001b[27mt\u001b[27m \u001b[27md\u001b[27mo\u001b[27mc\u001b[27mk\u001b[27me\u001b[27mr\u001b[27m-\u001b[27mc\u001b[27mo\u001b[27mm\u001b[27mp\u001b[27mo\u001b[27ms\u001b[27me\u001b[27m.\u001b[27my\u001b[27mm\u001b[27ml\u001b[1B\r\u001b[K\u001b[?2004l\r\r\n"]
[0.007, "o", "services:\r\n  db:\r\n    image: mysql:8.0\r\n    environment:\r\n      MYSQL_ROOT_PASSWORD: rootpass\r\n      MYSQL_DATABASE: tasks_db\r\n      MYSQL_USER: tasks_user\r\n      MYSQL_PASSWORD: tasks_pass\r\n    volumes:\r\n      - mysql_data:/var/lib/mysql\r\n    healthcheck:\r\n      test: [\"CMD\", \"mysqladmin\", \"ping\", \"-h\", \"127.0.0.1\", \"-uroot\", \"-prootpass\"]\r\n      interval: 5s\r\n      timeout: 5s\r\n      retries: 10\r\n    restart: unless-stopped\r\n\r\n  web:\r\n    build: .\r\n    ports:\r\n      - \"8000:8000\"\r\n    environment:\r\n      DATABASE_URL: mysql+aiomysql://tasks_user:tasks_pass@db:3306/tasks_db\r\n      SECRET_KEY: docker-secret-key-for-homework-32chars\r\n    depends_on:\r\n      db:\r\n        condition: service_healthy\r\n    restart: unless-stopped\r\n\r\nvolumes:\r\n  mysql_data:\r\n"]
